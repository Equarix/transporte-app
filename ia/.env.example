# API Key de OpenAI / Groq
OPENAI_API_KEY=your_openai_or_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Configuración de Chatwoot
CHATWOOT_BASE_URL=http://localhost:8080
CHATWOOT_API_TOKEN=your_chatwoot_access_token_here

# Configuración de la API principal de Transporte (NestJS)
MAIN_API_URL=http://localhost:5000/api

# Credenciales del Bot de Reservas (se registrará automáticamente si no existe en NestJS)
BOT_DOCUMENT_TYPE=DNI
BOT_DOCUMENT_NUMBER=99999999
BOT_PASSWORD=botpassword123
BOT_FIRST_NAME=Bot
BOT_LAST_NAME=Entrafesa
BOT_EMAIL=bot@entrafesa.com
BOT_PHONE=999999999
BOT_DATE_OF_BIRTH=2000-01-01

# URL pública de la aplicación web (para generar enlaces de pago al usuario)
APP_URL=http://localhost:3000
