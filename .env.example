# =========================================================================
# CONFIGURACIÓN DEL ENTORNO DE APIS Y BACKEND (ENTRAFESA)
# =========================================================================

# -------------------------------------------------------------------------
# 1. Base de datos externa (MS SQL Server)
# -------------------------------------------------------------------------
# Host de SQL Server. Si SQL Server corre localmente en tu host, usa:
# - En Windows/macOS: host.docker.internal
# - En Linux: 172.17.0.1 (o la IP local de tu host)
DB_HOST=host.docker.internal
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=123
DB_NAME=transporte
DB_NAME_SALES=transporte_sales

# -------------------------------------------------------------------------
# 2. Configuración API Principal (NestJS - Puerto 5000)
# -------------------------------------------------------------------------
JWT_SECRET=TuSecretoJWT
IA_INTERNAL_KEY=internal-secret-key-change-in-production

# -------------------------------------------------------------------------
# 3. Configuración del Módulo de Inteligencia Artificial (Python - Puerto 8000)
# -------------------------------------------------------------------------
# API Key de OpenAI o proveedor compatible (ej: OpenRouter)
OPENAI_API_KEY=sk-or-v1-
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=google/gemma-4-31b-it:free

# Token de acceso de administrador de Chatwoot (se obtiene de Ajustes de Perfil en Chatwoot)
CHATWOOT_API_TOKEN=D11JKfJpzXtLyikK4KV7ptEG
INTERNAL_SECRET_KEY=https://chatwoot-chatwoot.up0fay.easypanel.host

# Datos del bot de reservas para la IA (se creará automáticamente en NestJS)
BOT_DOCUMENT_TYPE=DNI
BOT_DOCUMENT_NUMBER=99999999
BOT_PASSWORD=botpassword123
BOT_FIRST_NAME=Bot
BOT_LAST_NAME=Entrafesa
BOT_EMAIL=bot@entrafesa.com
BOT_PHONE=999999999
BOT_DATE_OF_BIRTH=2000-01-01
